# Copy this file to .env and adjust values for your machine.
# Do NOT commit .env

# LM Studio OpenAI-compatible server (runs on the host)
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=qwen2.5-7b-instruct-uncensored
LM_STUDIO_EMBEDDING_MODEL=text-embedding-mxbai-embed-large-v1
LM_STUDIO_TIMEOUT_SECONDS=300
LM_STUDIO_EMBEDDING_BATCH_SIZE=1

# Ollama (alternative to LM Studio for embeddings)
# If OLLAMA_EMBEDDING_MODEL is set, it takes priority over LM_STUDIO_EMBEDDING_MODEL
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# Supabase (required for chat history and session persistence)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Qdrant API key if you enable it
# QDRANT_API_KEY=
